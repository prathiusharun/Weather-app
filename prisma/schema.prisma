// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
  

}

model SavedCity {
  id        String   @id @default(cuid())
  name      String @unique
  country   String?
  lat       Float
  lon       Float
  createdAt DateTime @default(now())
}